import HomePage from "@/components/HomePage.astro";
import { getTranslations } from "@/i18n/utils";

const locale = "en";
const t = getTranslations(locale);
---

<BaseLayout
  title="Cecilia Gutierrez — Personal Website"
  description="Cecilia Gutierrez — Senior Fullstack Engineer at N26, artist, and writer. Based in Barcelona, from Uruguay."
  locale={locale}
>
  <HomePage t={t} locale={locale} />
</BaseLayout>
