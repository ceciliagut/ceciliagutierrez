---
import ArrowUpRight from "@/components/icons/ArrowUpRight.astro";
import SubstackFeed from "@/components/sections/SubstackFeed.astro";
import type { Translations, Locale } from "@/i18n/translations";

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;

const writings = [
  {
    title: "Substack",
    url: "https://substack.com/@ceciliagutierrez",
    description: t.writing.substack,
  },
  {
    title: "Medium",
    url: "https://medium.com/@gutierrez-cecilia",
    description: t.writing.medium,
  },
];
---

<section id="writing" class="relative py-16 md:py-24 px-8 md:px-16">
  <div class="max-w-3xl mx-auto">
    <div data-animate class="text-center mb-20">
      <span class="font-body text-[11px] tracking-[0.4em] uppercase text-muted-foreground mb-6 block">
        {t.writing.label}
      </span>
      <h2 class="font-display text-4xl md:text-6xl font-medium">
        {t.writing.heading} <span class="italic">{t.writing.headingAccent}</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {writings.map((item) => (
        <a
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
          data-animate
          class="group block p-10 md:p-12 border border-border hover:border-foreground/20 transition-all duration-500 relative"
        >
          <div class="flex items-start justify-between mb-8">
            <h3 class="font-display text-2xl md:text-3xl font-medium text-foreground">
              {item.title}
            </h3>
            <ArrowUpRight
              size={18}
              class="text-muted-foreground group-hover:text-foreground group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300 mt-2"
            />
          </div>
          <p class="font-body text-sm leading-[1.8] text-muted-foreground">
            {item.description}
          </p>
        </a>
      ))}
    </div>

    <SubstackFeed t={t} locale={locale} />
  </div>
</section>
