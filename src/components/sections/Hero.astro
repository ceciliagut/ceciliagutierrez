---
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import type { Translations } from "@/i18n/translations";

interface Props {
  t: Translations;
  locale: "en" | "es";
}

const { t, locale } = Astro.props;
---

<!-- White header bar -->
<nav class="bg-background flex justify-between items-center px-8 md:px-16 py-8">
  <div></div>
  <div
    class="flex items-center gap-10 font-body text-[11px] tracking-[0.25em] uppercase text-muted-foreground opacity-0 animate-fade-in"
    style="animation-delay: 0.5s"
  >
    <a href="#about" class="hover:text-foreground transition-colors duration-300 hidden md:block">{t.nav.about}</a>
    <a href="#gallery" class="hover:text-foreground transition-colors duration-300 hidden md:block">{t.nav.work}</a>
    <a href="#writing" class="hover:text-foreground transition-colors duration-300 hidden md:block">{t.nav.writing}</a>
    <a href="#mentoring" class="hover:text-foreground transition-colors duration-300 hidden md:block">{t.nav.mentoring}</a>
    <a href="#connect" class="hover:text-foreground transition-colors duration-300 hidden md:block">{t.nav.connect}</a>
    <LanguageSwitcher locale={locale} />
    <ThemeToggle />
  </div>
</nav>

<!-- Hero image section -->
<section class="relative h-[70vh] max-h-[700px] md:max-h-[800px] flex flex-col">
  <div class="absolute inset-0 z-0">
    <img
      src="/hero-photo-bw.jpg"
      alt="Cecilia Gutierrez smiling at a train station"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="w-full h-full object-cover"
      style="object-position: 50% 100%"
    />
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <div class="relative z-10 flex-1 flex flex-col items-center justify-center text-center px-6">
    {t.hero.location && (
      <p
        class="font-body text-[11px] tracking-[0.4em] uppercase text-white/80 mb-10 opacity-0 animate-fade-up"
        style="animation-delay: 0.3s"
      >
        {t.hero.location}
      </p>
    )}

    <p
      class="font-body text-sm md:text-base tracking-wide text-white/80 mb-3 opacity-0 animate-fade-up"
      style="animation-delay: 0.4s"
    >
      {t.hero.greeting}
    </p>

    <h1
      class="font-display text-6xl md:text-8xl lg:text-9xl font-medium leading-[0.9] tracking-tight text-white opacity-0 animate-fade-up"
      style="animation-delay: 0.5s"
    >
      Cecilia
      <br />
      <span class="italic">Gutierrez</span>
    </h1>

    {(t.hero.tagline || t.hero.taglineItalic) && (
      <p
        class="font-body text-base md:text-lg text-white/90 max-w-md leading-relaxed mt-10 opacity-0 animate-fade-up"
        style="animation-delay: 1.2s"
      >
        {t.hero.tagline}
        {t.hero.taglineItalic && (
          <>
            <br /><span class="italic">{t.hero.taglineItalic}</span>
          </>
        )}
      </p>
    )}
  </div>

</section>
