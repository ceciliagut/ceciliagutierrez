---
import GalleryIsland from "@/components/gallery/GalleryIsland";
import type { Translations } from "@/i18n/translations";

interface Props {
  t: Translations;
  locale: string;
}

const { t, locale } = Astro.props;
---

<section id="gallery" class="relative pt-10 pb-20 md:pt-16 md:pb-28 px-8 md:px-16">
  <div class="max-w-6xl mx-auto">
    <div data-animate class="text-center mb-16">
      <span class="font-body text-[11px] tracking-[0.4em] uppercase text-muted-foreground mb-6 block">
        {t.gallery.label}
      </span>
      <h2 class="font-display text-4xl md:text-6xl font-medium text-card-foreground">
        {t.gallery.heading} <span class="italic">{t.gallery.headingAccent}</span>
      </h2>
    </div>

    <GalleryIsland
      client:visible
      categoryLabels={t.gallery.categories}
      locale={locale}
    />
  </div>
</section>
