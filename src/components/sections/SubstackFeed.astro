---
import ArrowUpRight from "@/components/icons/ArrowUpRight.astro";
import { getLatestPosts } from "@/lib/substack";
import type { Translations, Locale } from "@/i18n/translations";

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;

const latestPosts = await getLatestPosts(3);

function formatDate(dateStr: string): string {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString(locale === "es" ? "es-ES" : "en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  } catch {
    return "";
  }
}
---

{latestPosts.length > 0 && (
  <div class="mt-20">
    <h3 data-animate class="font-display text-xl md:text-2xl font-medium text-center mb-10">
      {t.writing.latestPosts}
    </h3>
    <div class="space-y-6">
      {latestPosts.map((post) => (
        <a
          href={post.url}
          target="_blank"
          rel="noopener noreferrer"
          data-animate
          class="group flex border border-border hover:border-foreground/20 transition-all duration-500 overflow-hidden"
        >
          {post.image && (
            <div class="w-36 md:w-52 flex-shrink-0">
              <img
                src={post.image}
                alt={post.title}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
          )}
          <div class="flex-1 min-w-0 p-6 md:p-8 flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <h4 class="font-display text-lg md:text-xl font-medium text-foreground group-hover:text-foreground/80 transition-colors duration-300">
                {post.title}
              </h4>
              {post.pubDate && (
                <time class="font-body text-xs tracking-wide text-muted-foreground/60 mt-2 block">
                  {formatDate(post.pubDate)}
                </time>
              )}
              {post.description && (
                <p class="font-body text-sm leading-[1.8] text-muted-foreground mt-3 line-clamp-2">
                  {post.description}
                </p>
              )}
            </div>
            <ArrowUpRight
              size={16}
              class="text-muted-foreground group-hover:text-foreground group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300 mt-1 flex-shrink-0"
            />
          </div>
        </a>
      ))}
    </div>
  </div>
)}

<div data-animate class="mt-16 text-center">
  <p class="font-body text-sm text-muted-foreground mb-2">
    {t.writing.subscribeDescription}
  </p>
  <iframe
    id="substack-embed"
    src="https://ceciliagutierrez.substack.com/embed?transparent=1"
    width="100%"
    height="150"
    style="border: 0; background: transparent;"
    frameborder="0"
    scrolling="no"
  ></iframe>
  <script>
    function updateSubstackEmbed() {
      const isDark = document.documentElement.classList.contains("dark");
      const base = "https://ceciliagutierrez.substack.com/embed?transparent=1";
      const src = isDark ? `${base}&light=1` : base;
      const iframe = document.getElementById("substack-embed") as HTMLIFrameElement | null;
      if (iframe && iframe.src !== src) iframe.src = src;
    }
    updateSubstackEmbed();
    new MutationObserver(updateSubstackEmbed).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  </script>
</div>
